APP_NAME="Issue Intake"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://127.0.0.1:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE is set automatically to database/database.sqlite when using sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Optional: only if calling the API from a different origin during development
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8000

# Optional: set OPENAI_API_KEY to use LLM summary generation (falls back to rules engine without it)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
